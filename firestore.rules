rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helper Functions ──
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Member helper functions (reads from /shops/{shopId}/members/{uid})
    function getMemberData(shopId) {
      return get(/databases/$(database)/documents/shops/$(shopId)/members/$(request.auth.uid)).data;
    }

    function isShopMember(shopId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/shops/$(shopId)/members/$(request.auth.uid)) &&
        getMemberData(shopId).isActive == true;
    }

    function hasRole(shopId, role) {
      return isShopMember(shopId) && getMemberData(shopId).role == role;
    }

    function hasAnyRole(shopId, roles) {
      return isShopMember(shopId) && getMemberData(shopId).role in roles;
    }

    // ── Users Collection ──
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow list: if false; // Block scanning profiles
      allow create: if isOwner(uid) 
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() < 100
        && !('editPin' in request.resource.data)
        && !('editPinRecoveryCode' in request.resource.data);
      allow update: if isOwner(uid)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'email', 'createdAt', 'isActive', 'role', 
          'editPin', 'editPinRecoveryCode'
        ]));
      allow delete: if false;
    }

    // ── Shops Collection & Sub-collections ──
    match /shops/{shopId} {
      allow get: if isShopMember(shopId) || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isShopMember(shopId) && hasRole(shopId, 'owner');
      allow delete: if false;

      // Members Subcollection
      match /members/{memberUid} {
        allow read: if isShopMember(shopId) || (isSignedIn() && request.auth.uid == memberUid);
        allow write: if isSignedIn() && (request.auth.uid == memberUid || (isShopMember(shopId) && hasRole(shopId, 'owner')));
      }

      // Products Subcollection
      match /products/{productId} {
        allow read: if isShopMember(shopId);
        allow create: if hasAnyRole(shopId, ['owner', 'manager'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() < 150
          && request.resource.data.sellingPrice is number
          && request.resource.data.sellingPrice >= 0
          && (!('costPrice' in request.resource.data) || request.resource.data.costPrice >= 0)
          && (!('quantity' in request.resource.data) || request.resource.data.quantity is number)
          && request.resource.data.isActive == true;
        allow update: if hasAnyRole(shopId, ['owner', 'manager'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() < 150
          && request.resource.data.sellingPrice is number
          && request.resource.data.sellingPrice >= 0
          && (!('costPrice' in request.resource.data) || request.resource.data.costPrice >= 0)
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt']));
        allow delete: if hasRole(shopId, 'owner');
      }

      // Categories Subcollection
      match /categories/{categoryId} {
        allow read: if isShopMember(shopId);
        allow write: if hasAnyRole(shopId, ['owner', 'manager']);
      }

      // Transactions Subcollection (Audit collection — Direct write DENIED)
      match /transactions/{transactionId} {
        allow read: if hasAnyRole(shopId, ['owner', 'manager', 'cashier']);
        allow write: if false; // Backend only
      }

      // Stock Movements Subcollection (Audit collection — Direct write DENIED)
      match /stock_movements/{movementId} {
        allow read: if hasAnyRole(shopId, ['owner', 'manager']);
        allow write: if false; // Backend only
      }

      // Scan History Subcollection
      match /scan_history/{scanId} {
        allow read: if isShopMember(shopId);
        allow create: if hasAnyRole(shopId, ['owner', 'manager', 'cashier']);
        allow update, delete: if false;
      }

      // Notifications Subcollection (System generated — Direct create/delete DENIED, read allowed, update for 'read' flag only)
      match /notifications/{notificationId} {
        allow read: if isShopMember(shopId);
        allow create, delete: if false; // Backend only
        allow update: if isShopMember(shopId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }

      // Analytics Snapshots Subcollection (Backend owned)
      match /analytics_snapshots/{dateKey} {
        allow read: if hasAnyRole(shopId, ['owner', 'manager']);
        allow write: if false; // Backend only
      }

      // In Demand Subcollection
      match /in_demand/{demandId} {
        allow read: if isShopMember(shopId);
        allow write: if hasAnyRole(shopId, ['owner', 'manager', 'cashier']);
      }

      // Settings Subcollection
      match /settings/{docId} {
        allow read: if isShopMember(shopId);
        allow write: if isShopMember(shopId) || (isSignedIn() && request.auth.uid != null);
      }

      // FCM Tokens Subcollection
      match /fcmTokens/{tokenId} {
        allow read: if isShopMember(shopId);
        allow create, update: if isShopMember(shopId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.platform in ['ios', 'android', 'web']
          && request.resource.data.keys().hasOnly(['uid', 'token', 'platform', 'updatedAt', 'createdAt']);
        allow delete: if isShopMember(shopId)
          && (resource.data.uid == request.auth.uid || hasRole(shopId, 'owner'));
      }
    }
  }
}
